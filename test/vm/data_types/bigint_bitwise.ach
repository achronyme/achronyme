// BigInt bitwise operations, shifts, to_bits/from_bits

// --- Bitwise AND ---
let a = bigint256("0xFF")
let b = bigint256("0x0F")
assert(a.bit_and(b) == bigint256("0x0F"))

// --- Bitwise OR ---
assert(bigint256("0xF0").bit_or(bigint256("0x0F")) == bigint256("0xFF"))

// --- Bitwise XOR ---
assert(bigint256("0xFF").bit_xor(bigint256("0x0F")) == bigint256("0xF0"))

// --- Bitwise NOT ---
// NOT of zero = all ones (max value)
let zero = bigint256(0)
let max = zero.bit_not()
// NOT(NOT(x)) == x
assert(max.bit_not() == zero)

// NOT(0x0F) should flip bits
let x = bigint256("0x0F")
let nx = x.bit_not()
// AND of x and NOT(x) should be zero
assert(x.bit_and(nx) == bigint256(0))
// OR of x and NOT(x) should be max
assert(x.bit_or(nx) == max)

// --- Shift left ---
assert(bigint256(1).bit_shl(8) == bigint256(256))
assert(bigint256(1).bit_shl(0) == bigint256(1))

// --- Shift right ---
assert(bigint256(256).bit_shr(8) == bigint256(1))
assert(bigint256(255).bit_shr(4) == bigint256(15))

// --- to_bits / from_bits roundtrip ---
let val = bigint256(42)
let bits = val.to_bits()
assert(bits.len() == 256)
// 42 = 0b101010, LSB-first: [0,1,0,1,0,1,0,0,...]
assert(bits[0] == 0)
assert(bits[1] == 1)
assert(bits[2] == 0)
assert(bits[3] == 1)
assert(bits[4] == 0)
assert(bits[5] == 1)

let reconstructed = from_bits(bits, 256)
assert(reconstructed == val)

// 512-bit roundtrip
let big = bigint512(12345)
let big_bits = big.to_bits()
assert(big_bits.len() == 512)
let big_back = from_bits(big_bits, 512)
assert(big_back == big)

// --- Shift roundtrip ---
let s = bigint256(1)
let shifted = s.bit_shl(100)
let back = shifted.bit_shr(100)
assert(back == s)

print("PASS: data_types/bigint_bitwise")
