// Prove block: for-loop with a mutable accumulator carried across
// iterations.
//
// Phase 1.B fixture (post fix/prove-for-loop-mut-rebinding) — exercises
// the natural `mut acc + for { acc = acc + ... }` pattern that the
// carry-set predicate detects and eager-unrolls at lower time. Each
// iteration's body re-walks the source AST so the inline SSA chain
// reads the previous iteration's output. Cross-path baseline pins
// Lysis-vs-Legacy byte-identity here.

let secret_a = 0p1
let secret_b = 0p2
let secret_c = 0p3
let secret_d = 0p4
let total = 0p10

prove(total: Public) {
    let arr: Field[4] = [secret_a, secret_b, secret_c, secret_d]
    mut acc: Field = 0p0
    for i in 0..4 {
        acc = acc + arr[i]
    }
    assert_eq(acc, total)
}

print("PASS: prove_for_loop")
