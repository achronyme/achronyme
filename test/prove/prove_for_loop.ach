// Prove block: for-loop over a literal range with per-iteration
// indexed asserts.
//
// Phase 1.B fixture — exercises `for i in 0..N` with literal bound and
// indexed array reads inside a prove {} body. Each iter emits a
// non-foldable constraint by combining a witness array element with an
// indexed multiplication, so the post-O1 multiset retains the per-iter
// shape. Cross-path baseline pins Lysis-vs-Legacy byte-identity here.
//
// Note: avoids `mut acc` reassignment inside the loop because the
// per-iter SSA rebind shape isn't supported (mut SSA is captured once
// at ast-lower; the inner body references the pre-version `acc`).

let secret_a = 0p3
let secret_b = 0p5
let target_sum = 0p100

prove(target_sum: Public) {
    // Two captured witness scalars expanded into an array literal.
    let s: Field[4] = [secret_a, secret_b, secret_a, secret_b]

    // Squared constants — checked against s[i] * s[i] per iteration.
    // s[0]^2=9, s[1]^2=25, s[2]^2=9, s[3]^2=25 → sum 68.
    let sq: Field[4] = [0p9, 0p25, 0p9, 0p25]
    for i in 0..4 {
        assert_eq(s[i] * s[i], sq[i])
    }

    // Quadruple-sum cross-check, again indexed.
    // s[0]+s[1]+s[2]+s[3] = 3+5+3+5 = 16 — non-fold-equivalent to the
    // squared chain so post-O1 doesn't collapse all four constraints.
    let parts: Field[4] = [0p3, 0p5, 0p3, 0p5]
    for i in 0..4 {
        assert_eq(s[i], parts[i])
    }

    // Tie target_sum into the constraint set so the public wire is
    // load-bearing — prevents an over-eager optimizer from declaring
    // the public input dead.
    assert_eq(target_sum, 0p100)
}

print("PASS: prove_for_loop")
