// Circuit: nested for-loop accumulation (3x3 matrix sum)
circuit nested_loops(out: Public) {
    // sum of (i+1)*(j+1) for i in 0..3, j in 0..3
    // = (1+2+3) + (2+4+6) + (3+6+9) = 6+12+18 = 36
    mut acc = 0
    for i in 0..3 {
        for j in 0..3 {
            acc = acc + (i + 1) * (j + 1)
        }
    }
    assert_eq(acc, out)
}
