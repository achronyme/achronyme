// Circuit: chained boolean logic with comparisons
circuit complex_boolean(a: Witness, b: Witness, c: Witness, d: Witness, e: Witness, f: Witness) {
    // (a < b) && (c > d) || !(e == f)
    let r1 = a < b
    let r2 = c > d
    let r3 = e == f
    let r4 = r1 && r2
    let r5 = !r3
    let r6 = r4 || r5
    assert(r6)
}
