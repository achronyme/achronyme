// Circuit: arithmetic with type annotations
circuit typed_arithmetic(out: Public Field, a: Witness Field, b: Witness Field) {
    // Typed let bindings
    let product: Field = a * b
    assert_eq(product, out)

    let sum: Field = a + b
    assert_eq(sum, a + b)

    let diff: Field = b - a
    assert_eq(diff, b - a)

    // Untyped let mixed with typed inputs (gradual typing)
    let doubled = a + a
    assert_eq(doubled, a * 2)
}
